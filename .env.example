PORT=5174
BASE_URL=http://127.0.0.1:5174

# Leave SMTP_HOST empty to run in safe simulation mode.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

FROM_NAME=
FROM_EMAIL=
REPLY_TO=
COMPANY_ADDRESS=

# Microsoft Graph OAuth, recommended for Microsoft 365 sending and reply sync.
# In Azure, add this redirect URI:
# http://127.0.0.1:5174/api/microsoft/callback
MICROSOFT_TENANT_ID=organizations
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://127.0.0.1:5174/api/microsoft/callback
